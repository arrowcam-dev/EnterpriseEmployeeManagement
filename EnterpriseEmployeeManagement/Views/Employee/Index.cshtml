@{
    ViewData["Title"] = "Employees";
}

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h5 class="mb-0">Employee Management</h5>

        <div>

            <button type="button" class="btn btn-primary btn-sm" onclick="openCreateModal()">
                <i class="bi bi-plus-lg"></i> New Employee
            </button>

            <a asp-action="Deleted" class="btn btn-outline-secondary btn-sm">
                Deleted
            </a>

        </div>

    </div>


    <div class="card-body">

        <form method="get" class="row g-2 mb-3">

            <div class="col-md-4">
                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>

                    <input id="searchBox" class="form-control" value="@Context.Request.Query["search"]" placeholder="Search employees..." />

                </div>
            </div>

            <div class="col-md-2">

                <select id="pageSize" name="pageSize" class="form-select">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>

            </div>

        </form>

        <div id="employeeTable">
        </div>

    </div>

</div>

<div class="modal fade" id="employeeModal" tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">Employee</h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body" id="employeeModalBody">

                Loading...

            </div>

        </div>

    </div>

</div>

<div class="modal fade" id="deleteModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">Confirm Delete</h5>

                <button class="btn-close" data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                Are you sure you want to delete this employee?

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary" data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-danger" id="confirmDeleteBtn">

                    Delete

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/employees.js" asp-append-version="true"></script>
}
