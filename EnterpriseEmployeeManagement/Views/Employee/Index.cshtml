@{
    ViewData["Title"] = "Employees";
}

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h5 class="mb-0">Employee Management</h5>

        <div>

            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg"></i> New Employee
            </a>

            <a asp-action="Deleted" class="btn btn-outline-secondary btn-sm">
                Deleted
            </a>

        </div>

    </div>


    <div class="card-body">

        <form method="get" class="row g-2 mb-3">

            <div class="col-md-4">

                <input type="text"
                       name="searchBox"
                       id="searchBox"
                       value="@Context.Request.Query["search"]"
                       class="form-control"
                       placeholder="Search employee...">

            </div>

            <div class="col-md-2">

                <select id="pageSize" name="pageSize" class="form-select">

                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>

                </select>

            </div>

            <div class="col-md-2">

                <button class="btn btn-outline-primary w-100">
                    Search
                </button>

            </div>

        </form>

        <div id="employeeTable">
        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/employees.js" asp-append-version="true"></script>
}
