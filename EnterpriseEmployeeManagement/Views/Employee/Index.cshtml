@model EnterpriseEmployeeManagement.ViewModels.PagedResult<
EnterpriseEmployeeManagement.ViewModels.EmployeeListViewModel >

@{
    ViewData["Title"] = "Employees";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">

        <h2 class="mb-0">Employees</h2>

        <div>
            <a asp-action="Create" class="btn btn-primary me-2">
                <i class="bi bi-plus-lg"></i> Create Employee
            </a>

            <a asp-action="Deleted" class="btn btn-outline-secondary">
                Deleted Employees
            </a>
        </div>

    </div>


    <form method="get" class="row g-2 mb-3">

        <div class="col-md-4">

            <input type="text"
                   name="search"
                   value="@Context.Request.Query["search"]"
                   class="form-control"
                   placeholder="Search employees..." />

        </div>

        <div class="col-md-2">

            <button class="btn btn-outline-primary w-100">
                Search
            </button>

        </div>

    </form>


    <div class="card">

        <div class="card-body p-0">

            <table class="table table-striped table-hover mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Status</th>
                        <th style="width:160px">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center p-4">
                                No employees found
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model.Items)
                    {
                        <tr>

                            <td>@item.FullName</td>

                            <td>@item.Email</td>

                            <td>@item.DepartmentName</td>

                            <td>@item.Position</td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>

                            <td>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning me-1">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Delete this employee?');">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>


    @if (Model.TotalCount > Model.PageSize)
    {

        <nav class="mt-3">

            <ul class="pagination">

                @{
                    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
                }

                @for (int i = 1; i <= totalPages; i++)
                {

                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@Context.Request.Query["search"]">

                            @i

                        </a>

                    </li>

                }

            </ul>

        </nav>

    }

</div>