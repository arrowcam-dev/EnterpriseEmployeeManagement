@model EnterpriseEmployeeManagement.ViewModels.PagedResult<
EnterpriseEmployeeManagement.ViewModels.EmployeeListViewModel >

<div class="table-responsive">

    <table class="table table-hover align-middle">

        <thead class="table-light">

            <tr>

                <th>
                    <a href="#" onclick="CrudPage.sort('name'); return false;">
                        Name
                        <i id="sortIcon-name" class="ms-1"></i>
                    </a>
                </th>

                <th>
                    <a href="#" onclick="CrudPage.sort('email'); return false;">
                        Email
                        <i id="sortIcon-email" class="ms-1"></i>
                    </a>
                </th>

                <th>
                    <a href="#" onclick="CrudPage.sort('department'); return false;">
                        Department
                        <i id="sortIcon-department" class="ms-1"></i>
                    </a>
                </th>

                <th>Position</th>

                <th>Status</th>

                <th width="150">Actions</th>

            </tr>

        </thead>

        <tbody>

            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="6" class="text-center">No employees found</td>
                </tr>
            }

            @foreach (var item in Model.Items)
            {
                <tr>

                    <td>@item.FullName</td>

                    <td>@item.Email</td>

                    <td>@item.DepartmentName</td>

                    <td>@item.Position</td>

                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>

                    <td>
                        <button class="btn btn-sm btn-outline-warning" data-edit="@item.Id">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-outline-danger" data-delete="@item.Id">
                            Delete
                        </button>
                        
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>


@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<nav>

    <ul class="pagination justify-content-center">

        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == Model.PageNumber ? "active" : "")">

                <a href="#" class="page-link" onclick="CrudPage.loadPage(@i); return false;">
                    @i
                </a>

            </li>
        }

    </ul>

</nav>