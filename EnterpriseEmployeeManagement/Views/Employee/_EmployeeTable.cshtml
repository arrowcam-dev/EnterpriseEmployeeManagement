@model EnterpriseEmployeeManagement.ViewModels.PagedResult<
EnterpriseEmployeeManagement.ViewModels.EmployeeListViewModel >

<div class="table-responsive">

    <table class="table table-hover align-middle">

        <thead class="table-light">

            <tr>

                <th>
                    <a href="#" data-sort="name">
                        Name
                        <i id="sortIcon-name" class="ms-1"></i>
                    </a>
                </th>

                <th>
                    <a href="#" data-sort="email">
                        Email
                        <i id="sortIcon-email" class="ms-1"></i>
                    </a>
                </th>

                <th>
                    <a href="#" data-sort="department">
                        Department
                        <i id="sortIcon-department" class="ms-1"></i>
                    </a>
                </th>

                <th>Position</th>

                <th>Status</th>

                <th width="200" class="text-center">Actions</th>

            </tr>

        </thead>

        <tbody>

            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="6" class="text-center">No employees found</td>
                </tr>
            }

            @foreach (var item in Model.Items)
            {
                <tr>

                    <td>@item.FullName</td>

                    <td>@item.Email</td>

                    <td>@item.DepartmentName</td>

                    <td>@item.Position</td>

                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>

                    <td>
                        <button class="btn btn-info btn-sm" data-action="details" data-id="@item.Id">
                            Details
                        </button>
                        <button class="btn btn-sm btn-outline-warning" data-action="edit" data-id="@item.Id">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-outline-danger" data-action="delete" data-id="@item.Id" data-name="@item.FullName">
                            Delete
                        </button>
                        
                    </td>

                </tr>
            }

        </tbody>
    </table>

</div>

@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<nav>

    <ul class="pagination justify-content-center">

        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                <a href="#" class="page-link" data-page="@i">
                    @i
                </a>
            </li>
        }

    </ul>

</nav>