@using EnterpriseEmployeeManagement.ViewModels
@model DepartmentFormViewModel

<div class="d-none" data-modal-title="New Department"></div>

<form method="post" asp-action="CreateModal" data-ajax-form>
    <div class="alert alert-danger d-none" id="formError"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Last Name</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">
        Save
    </button>

</form>