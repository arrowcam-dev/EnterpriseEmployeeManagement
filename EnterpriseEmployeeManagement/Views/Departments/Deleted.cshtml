@model IEnumerable<EnterpriseEmployeeManagement.Models.Department>
@{
    ViewBag.Title = "Deleted Departments";
}

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h5 class="mb-0">Deleted Departments</h5>

    </div>
    <div class="card-body">
        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center">No deleted departments found.</td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Description</td>

                        <td class="text-center">
                            <a asp-action="Restore" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                                Restore
                            </a>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>



</div>