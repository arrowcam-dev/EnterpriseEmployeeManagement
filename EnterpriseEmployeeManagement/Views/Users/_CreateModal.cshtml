@using EnterpriseEmployeeManagement.ViewModels
@model UserEditViewModel

<div class="d-none" data-modal-title="Create New User"></div>
<form method="post" action="/Users/CreateModal" data-ajax-form>

    <div class="mb-3">

        <label asp-for="Username">Username</label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>

    </div>

    <div class="mb-3">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">

        <label>Password</label>

        <input asp-for="Password" class="form-control" />

    </div>

    <div class="mb-3">

        <label>Roles</label>

        @foreach (var role in Model.AvailableRoles)
        {
            var checkboxId = $"role_{role}".Replace(" ", "_");
            <div class="form-check">

                <input type="checkbox" id="@checkboxId" name="SelectedRoles" value="@role" class="form-check-input" />

                <label class="form-check-label" for="@checkboxId">
                    @role
                </label>

            </div>
        }

    </div>

    <button class="btn btn-primary">Save</button>

</form>